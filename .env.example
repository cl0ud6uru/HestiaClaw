PORT=3001
SESSION_SECRET=replace-with-a-long-random-secret

# ── DOCKER SETUP ──────────────────────────────────────────────────────────────
# When running via Docker Compose (docker compose up), Neo4j and Graphiti start
# automatically. Set a strong password here — it's shared by both containers.
NEO4J_PASSWORD=hestia-neo4j-password

# ── NATIVE SETUP (app running outside Docker) ─────────────────────────────────
# Point these at your running Neo4j instance. NEO4J_PASSWORD above is reused.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j

# ─────────────────────────────────────────────────────────────────────────────

N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-webhook-id

BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me-now

DATABASE_PATH=./data/hestia.sqlite
TRUST_PROXY=0
FRONTEND_ORIGIN=http://localhost:5173

ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_DEFAULT_VOICE_ID=your-default-elevenlabs-voice-id
ELEVENLABS_TTS_MODEL_ID=eleven_flash_v2_5
ELEVENLABS_STT_MODEL_ID=scribe_v2_realtime

# Native agent harness (requires agent.config.json — see agent.config.example.json)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
# SEARXNG_URL=http://your-searxng-instance.com

# HA webhook-conversation integration (POST /api/webhook/conversation)
# If set, the endpoint requires this as the Basic Auth password (any username).
# Leave blank to allow unauthenticated access (trusted LAN only).
WEBHOOK_SECRET=
