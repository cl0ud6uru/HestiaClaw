{
  "provider": {
    "type": "anthropic",
    "model": "claude-opus-4-7"
  },
  "harness": {
    "approvals": true,
    "approvalTimeoutMs": 60000,
    "compactionEnabled": true,
    "contextMaxMessages": 40,
    "systemPromptLocked": true,
    "toolPolicy": {
      "profile": "home-control",
      "overrides": {}
    }
  },
  "mcpServers": {
    "graphiti": {
      "url": "http://localhost:8001/mcp"
    },
    "home-assistant": {
      "url": "http://localhost:8002/mcp"
    }
  }
}
